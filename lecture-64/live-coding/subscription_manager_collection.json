{
  "info": {
    "_postman_id": "8f8dd38c-3106-4b35-95ab-aeafaf7c5382",
    "name": "subscription manager",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:9000"
    },
    {
      "key": "planCode",
      "value": "BASIC_199"
    },
    {
      "key": "subscriptionId",
      "value": ""
    },
    {
      "key": "invoiceId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Ping",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ping",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "ping"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List Plans",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/plans",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "plans"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "if (Array.isArray(data) && data.length > 0 && data[0].planCode) {",
              "    pm.collectionVariables.set('planCode', data[0].planCode);",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Get Plan",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/plans/{{planCode}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "plans",
            "{{planCode}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Create Subscription",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"planCode\": \"{{planCode}}\",\n  \"autoRenew\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/subscriptions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscriptions"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "if (data && data.id) {",
              "    pm.collectionVariables.set('subscriptionId', data.id);",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "List My Subscriptions",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/subscriptions/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscriptions",
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "if (Array.isArray(data) && data.length > 0) {",
              "    const active = data.find(item => item.status === 'ACTIVE') || data[0];",
              "    if (active && active.id) {",
              "        pm.collectionVariables.set('subscriptionId', active.id);",
              "    }",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "List My Invoices",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/invoices/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "invoices",
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "if (Array.isArray(data) && data.length > 0) {",
              "    const dueInvoice = data.find(item => item.status === 'DUE') || data[0];",
              "    if (dueInvoice && dueInvoice.id) {",
              "        pm.collectionVariables.set('invoiceId', dueInvoice.id);",
              "    }",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Pay Invoice",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/invoices/{{invoiceId}}/pay",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "invoices",
            "{{invoiceId}}",
            "pay"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Cancel Subscription",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/subscriptions/{{subscriptionId}}/cancel",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscriptions",
            "{{subscriptionId}}",
            "cancel"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "response": []
    }
  ]
}
